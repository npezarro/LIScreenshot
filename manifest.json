{
  "manifest_version": 3,
  "name": "LinkedIn Puzzle Screenshot Tool",
  "version": "1.0",
  "description": "Automatically screenshot LinkedIn puzzles and overlay spreadsheet data",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads"
  ],
  "web_accessible_resources": [
    {
      "resources": ["html2canvas.min.js", "lib/*"],
      "matches": ["*://*.linkedin.com/*"]
    }
  ],
  "host_permissions": [
    "*://*.linkedin.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}